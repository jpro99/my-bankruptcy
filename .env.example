# ChapterAI Environment Variables

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@host/chapterai?sslmode=require

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# AI Gateway
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Inngest (durable workflows)
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=chapterai-documents

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=...
UPSTASH_REDIS_REST_TOKEN=...

# App URLs
WEB_URL=http://localhost:3000
API_URL=http://localhost:3002

# CRS Credit API (Phase 2) — sandbox used when unset
CRS_CREDIT_API_KEY=
CRS_CREDIT_API_URL=https://api.crscreditapi.com/api

# Dev auth bypass (local only)
DEV_AUTH_BYPASS=1
