# ChapterAI — local development
DEV_AUTH_BYPASS=1

# API (used by Next.js web app)
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_DEV_AUTH_BYPASS=1

# Database (Neon PostgreSQL) — optional for demo mode
# DATABASE_URL=postgresql://...

# CRS Credit API — optional; uses sandbox tri-merge when unset
# CRS_CREDIT_API_KEY=
# CRS_CREDIT_API_URL=https://api.crscreditapi.com/api

# AI Gateway
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Inngest
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

WEB_URL=http://localhost:3000

# Outbound email (Resend) — portal invites, discharge follow-up
# RESEND_API_KEY=re_...
# OUTBOUND_EMAIL_FROM=Relief Team <noreply@yourfirm.com>

# Personal injury cross-sell (discharge follow-up emails)
# PI_FIRM_NAME=Smith & Associates Personal Injury
# PI_FIRM_PHONE=(555) 555-0100
# PI_FIRM_URL=https://yourfirm.com/personal-injury

# CM/ECF e-file bridge (optional — sandbox by default)
# EFILE_MODE=sandbox
# EFILE_BRIDGE_URL=http://localhost:3010
