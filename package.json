{
  "name": "chapterai",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run build --filter=@chapterai/web^... --filter=@chapterai/api^... --filter=@chapterai/worker^... && turbo run dev --filter=@chapterai/web --filter=@chapterai/api --filter=@chapterai/worker",
    "dev:clean": "node scripts/clean-dev.mjs && pnpm dev",
    "dev:all": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @chapterai/db generate",
    "db:migrate": "pnpm --filter @chapterai/db migrate",
    "db:push": "pnpm --filter @chapterai/db push"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
